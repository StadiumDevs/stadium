# API runtime data layer (Supabase) — required for `npm start` / `npm run dev`
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Multi-chain admin auth — comma-separated authorized signers.
# Each entry is either `chain:address` or a bare address (bare ⇒ substrate).
# Supported chains: substrate, ethereum. Example:
#   AUTHORIZED_SIGNERS=5Grw...,ethereum:0xAbC123...
# ADMIN_WALLETS is the legacy fallback, used only when AUTHORIZED_SIGNERS is empty.
ADMIN_WALLETS=
EXPECTED_DOMAIN=

# Runtime
NODE_ENV=development

# Admin session tokens — issued by POST /api/admin/session after one SIWS
# sign, then accepted as `Authorization: Bearer …` on subsequent admin
# requests so admins don't pop a wallet popup per action. The secret signs
# the HMAC; rotate to invalidate every live session.
#   ADMIN_SESSION_SECRET: 32+ chars, treat as a high-value secret
#   ADMIN_SESSION_TTL_SECONDS: defaults to 900 (15 min). Range 1..86400.
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_SECONDS=900

# Substrate network config
NETWORK_ENV=testnet
AUTHORIZED_SIGNERS=

# Notification service (Resend) — required for P2-03 provider wiring; unused until then
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Offline data tooling (Mongo via Mongoose) — only needed for `npm run seed:dev`,
# `db:migrate`, `db:reset`, `list:winners-zero-paid`, and other scripts/*.js.
# Not used by the running API.
MONGO_URI=
